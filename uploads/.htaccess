# Enable Rewrite Engine
RewriteEngine on

# Prevent hotlinking - Allow only yoururl.com (with and without www) and localhost
RewriteCond %{HTTP_REFERER} !^https?://(www\.)?(yoururl\.com|localhost) [NC]
RewriteCond %{HTTP_REFERER} !^$
RewriteRule \.(jpg|jpeg|png|gif|webp)$ - [F]

# Block direct access to image files
<FilesMatch "\.(jpg|jpeg|png|gif|webp)$">
  Require all denied
</FilesMatch>

# Allow access only when used within yoururl.com or localhost
<If "%{HTTP_REFERER} =~ m#^https?://(www\.)?(yoururl\.com|localhost)#">
  Require all granted
</If>

# Block directory listing
Options -Indexes
